<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aurafarming.controller.RegistrationController" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="AuraFarming Registration" styleClass="title"/>
    <TextField fx:id="fullNameField" promptText="Full Name" maxWidth="320"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="320"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="320"/>
    <ComboBox fx:id="roleCombo" maxWidth="320"/>
    <ComboBox fx:id="districtCombo" maxWidth="320"/>
    <TextField fx:id="phoneField" promptText="Phone (Farmer)" maxWidth="320"/>
    <Button text="Register" onAction="#onRegister" styleClass="primary-btn"/>
    <Button text="Login Instead" onAction="#onLoginInstead"/>
</VBox>
