<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aurafarming.controller.FarmerController">
    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
    <Label text="Farmer Management" styleClass="title"/>
    <TextField fx:id="searchField" promptText="Search by id/name/email"/>
    <Button text="Search" onAction="#onSearch"/>
    <Button text="Deactivate First Match" onAction="#onDeactivate"/>
    <TextArea fx:id="outputArea" prefHeight="320"/>
</VBox>
