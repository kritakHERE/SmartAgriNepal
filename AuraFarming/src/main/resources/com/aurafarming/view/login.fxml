<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aurafarming.controller.LoginController" styleClass="page-root">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
    <Label text="AuraFarming Login" styleClass="title"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="320"/>
    <Button text="Login" onAction="#onLogin" styleClass="primary-btn"/>
    <Button text="Go to Registration" onAction="#onGoRegister"/>
</VBox>
